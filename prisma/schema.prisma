generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =====================
// AUTH MODELS (NextAuth)
// =====================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =====================
// USER MODEL
// =====================

model User {
  id             String    @id @default(cuid())
  name           String?
  email          String?   @unique
  emailVerified  DateTime?
  image          String?
  hashedPassword String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  stats          UserStats?
  sessionResults SessionResult[]
  earnedBadges   UserBadge[]
}

// =====================
// GAMIFICATION MODELS
// =====================

model UserStats {
  id                  String   @id @default(cuid())
  userId              String   @unique
  totalXp             Int      @default(0)
  level               Int      @default(1)
  currentStreak       Int      @default(0)
  longestStreak       Int      @default(0)
  lastActiveDate      DateTime?
  scenariosCompleted  Int      @default(0)
  correctDecisions    Int      @default(0)
  totalDecisions      Int      @default(0)
  phishingAccuracy    Float    @default(0)
  pretextingAccuracy  Float    @default(0)
  vishingAccuracy     Float    @default(0)
  // Tactic weakness tracking
  urgencyMissRate     Float    @default(0)
  authorityMissRate   Float    @default(0)
  fearMissRate        Float    @default(0)
  curiosityMissRate   Float    @default(0)
  rewardMissRate      Float    @default(0)
  trustMissRate       Float    @default(0)
  updatedAt           DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String
  category    String      // milestone, streak, mastery, special
  condition   String      // JSON string describing unlock condition
  xpReward    Int         @default(0)
  createdAt   DateTime    @default(now())

  earnedBy    UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  earnedAt  DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

// =====================
// SCENARIO MODELS
// =====================

model SessionResult {
  id              String   @id @default(cuid())
  userId          String
  scenarioType    String   // phishing, pretexting, vishing
  difficulty      Int
  templateId      String
  userDecision    String   // reported, safe, resisted, manipulated
  isCorrect       Boolean
  xpEarned        Int      @default(0)
  flagsCaught     String[] // array of red flag IDs the user identified
  flagsMissed     String[] // array of red flag IDs the user missed
  tacticsUsed     String[] // manipulation tactics in this scenario
  tacticsMissed   String[] // tactics the user failed to identify
  timeSpentMs     Int      @default(0)
  completedAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, completedAt])
  @@index([userId, scenarioType])
}
